# MERN Application Environment Variables Template
# Copy this file to .env in both client and server directories and fill in the values

# Server Environment Variables (server/.env)
PORT=3000
NODE_ENV=development # Set to 'production' for deployment
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/bizcheck?retryWrites=true&w=majority

# API Keys
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here
FACEBOOK_ACCESS_TOKEN=your_facebook_access_token_here

# Puppeteer settings for production (e.g. Render, Heroku)
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome # Or path provided by hosting provider

# Scraper Debugging
DEBUG_SCRAPER=false

# Client Environment Variables (client/.env)
# The Vite proxy handles API routing in development, but for production, you need the actual backend URL
VITE_API_URL=http://localhost:3000 # E.g., https://your-backend.onrender.com
